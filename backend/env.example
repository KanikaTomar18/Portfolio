# Copy this file to .env for local testing (and NEVER commit the real .env to GitHub).
# On Render/Railway/etc, set these as "Environment Variables" in the dashboard instead.

# The Gmail account that will SEND the email on your behalf
EMAIL_ADDRESS=youraddress@gmail.com

# A Gmail "App Password" (NOT your normal Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be turned on for your Google account)
EMAIL_PASSWORD=your_16_character_app_password

# Where you want contact-form messages delivered (can be the same as EMAIL_ADDRESS)
TO_EMAIL=youraddress@gmail.com
